# ============================================================
# AI Money Mentor — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your actual values.
#
#   cp .env.example .env
#
# ⚠️  NEVER commit your .env file to version control.
#      The .env file is already listed in .gitignore.
# ============================================================

# ------------------------------------------------------------
# Groq API Key (REQUIRED)
# Obtain your key at: https://console.groq.com/
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# Flask Configuration
# Set to "production" when deploying; "development" for local.
# NEVER enable FLASK_DEBUG in production.
# ------------------------------------------------------------
FLASK_ENV=development
FLASK_DEBUG=1

# ------------------------------------------------------------
# Optional: OpenAI API Key (if switching AI provider)
# ------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here
